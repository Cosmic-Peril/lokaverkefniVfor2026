<%- include =('partials/header') %>

<section class="featured">
    <div style="
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    ">

        <h2 style="margin-bottom: 1.5rem; text-align: center;">
            Add a new disorder
        </h2>"

        <form action ="/disorder/ny" method="POST" style=>
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        ">
            <div>
                <label for="title" style"
                    font-weight: 600;
                    display: block;
                    margin-bottom: 0.5rem;
                ">Title *</label>"

                <input
                    type="text"
                    id="title"
                    name="title"
                    required
                >
            </div>